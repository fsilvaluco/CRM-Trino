# Auto-CRM - Variables de Entorno
# Copia este archivo como .env.local: cp .env.example .env.local

# =============================================================================
# SUPABASE (requerido para la versión online)
# Panel Supabase > Settings > API
# =============================================================================
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# NEXT_PUBLIC_SITE_URL=https://crm-trino-production.up.railway.app
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   (solo para scripts de seed/migración)
# SUPABASE_ORG_ID=<UUID>             (SELECT id FROM organizations LIMIT 1)
# SUPABASE_USER_ID=<UUID>            (SELECT id FROM auth.users LIMIT 1)

# =============================================================================
# OPCIONAL: API de Claude para clasificacion de leads con IA
# Si no se configura, el CRM usa scoring basado en reglas (funciona igual de bien)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# OPCIONAL: Email digest diario (registrate gratis en resend.com)
# =============================================================================
# RESEND_API_KEY=re_...
# DIGEST_EMAIL=tu@email.com
# DIGEST_FROM=Auto-CRM <onboarding@resend.dev>
