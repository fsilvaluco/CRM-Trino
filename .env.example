# Auto-CRM - Variables de Entorno
# Copia este archivo como .env.local: cp .env.example .env.local

# =============================================================================
# SUPABASE (requerido para la versión online)
# Panel Supabase > Settings > API
# =============================================================================
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# NEXT_PUBLIC_SITE_URL=https://crm-trino-production.up.railway.app
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   (solo para scripts de seed/migración)
# SUPABASE_ORG_ID=<UUID>             (SELECT id FROM organizations LIMIT 1)
# SUPABASE_USER_ID=<UUID>            (SELECT id FROM auth.users LIMIT 1)

# =============================================================================
# OPCIONAL: API de Claude para clasificacion de leads con IA
# Si no se configura, el CRM usa scoring basado en reglas (funciona igual de bien)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-...

# Usado solo para leer pantallazos de Spotify for Artists (más barato que
# Anthropic para esta tarea puntual). Conseguir en aistudio.google.com/apikey
# GEMINI_API_KEY=

# =============================================================================
# OPCIONAL: Email digest diario (registrate gratis en resend.com)
# =============================================================================
# RESEND_API_KEY=re_...
# DIGEST_EMAIL=tu@email.com
# DIGEST_FROM=Auto-CRM <onboarding@resend.dev>

# =============================================================================
# CRON: sync diario de Instagram (4am) — /api/cron/sync-instagram
# Genera un secret random (ej: openssl rand -hex 32) y configuralo también
# en el Railway Cron Job que llama a este endpoint.
# =============================================================================
# CRON_SECRET=

# =============================================================================
# SHOPIFY (Merch) — app OAuth en Shopify Partners
# Creala en partners.shopify.com > Apps > Crear app, distribución "Custom" o
# "Public" sin publicar en el App Store (no requiere revisión de Shopify
# mientras no se liste públicamente) — necesario porque a futuro otros
# artistas van a conectar sus propias tiendas, no solo la de Katarsis.
# Scopes a configurar: read_products, read_inventory, read_orders.
# Redirect URL a registrar en el Partner Dashboard:
#   https://artistpro.app/api/integrations/shopify/callback
# =============================================================================
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_REDIRECT_URI=https://artistpro.app/api/integrations/shopify/callback

# =============================================================================
# CRON: sync diario de Shopify (Merch) — /api/cron/sync-shopify
# Reusa el mismo CRON_SECRET de arriba. El access token de cada tienda NO
# vive en variables de entorno — se guarda por proyecto en artist_integrations
# (platform='shopify') al conectar desde la UI (Métricas > Merch).
# =============================================================================
